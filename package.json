{
  "name": "@tokiya-takai/par",
  "version": "0.2.0",
  "description": "Local-first review cockpit for the sole reviewer of an outsourced, AI-heavy codebase — multi-repo, multi-PR, with repo-grounded AI Q&A.",
  "keywords": [
    "code-review",
    "pull-request",
    "cli",
    "git-worktree",
    "gh",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "author": "Tokiya Takai",
  "homepage": "https://github.com/tokiya-takai/par#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokiya-takai/par.git"
  },
  "bugs": {
    "url": "https://github.com/tokiya-takai/par/issues"
  },
  "type": "module",
  "bin": {
    "par": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json && npm run build:ui",
    "build:ui": "tsc -p ui/tsconfig.json && vite build --config ui/vite.config.ts",
    "dev": "tsup --watch",
    "dev:ui": "vite --config ui/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/refractor": "^3.4.1",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-diff-view": "^3.3.3",
    "react-dom": "^18.3.1",
    "refractor": "^3.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.30"
  }
}
