{
  "name": "@tokiya-takai/par",
  "version": "0.1.0",
  "description": "Local-first review cockpit for the sole reviewer of an outsourced, AI-heavy codebase — multi-repo, multi-PR, with repo-grounded AI Q&A.",
  "keywords": [
    "code-review",
    "pull-request",
    "cli",
    "git-worktree",
    "gh",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "author": "Tokiya Takai",
  "homepage": "https://github.com/tokiya-takai/par#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tokiya-takai/par.git"
  },
  "bugs": {
    "url": "https://github.com/tokiya-takai/par/issues"
  },
  "type": "module",
  "bin": {
    "par": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
